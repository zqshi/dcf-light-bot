NODE_ENV=development
HOST=127.0.0.1
PORT=3000

DATA_DIR=./data
LOGS_DIR=./logs
CONTROL_PLANE_STORE=./data/control-plane.json
PERSISTENCE_BACKEND=file
POSTGRES_URL=
POSTGRES_SCHEMA=public
POSTGRES_TABLE=control_plane_store
POSTGRES_ROW_KEY=main

KUBERNETES_SIMULATION_MODE=true
KUBERNETES_RECONCILE_ENABLED=true
KUBERNETES_ROLLBACK_ON_PROVISION_FAILURE=true
KUBERNETES_NAMESPACE_PREFIX=dcf
OPENCLAW_IMAGE=openclaw/openclaw:2026.2.27
OPENCLAW_RUNTIME_VERSION=2026.2.27
OPENCLAW_SOURCE_PATH=/Users/zqs/Downloads/project/dependencies/openclaw

PLATFORM_BASE_URL=http://localhost:3000
TENANT_DEFAULT_CPU=200m
TENANT_DEFAULT_MEMORY=512Mi
TENANT_DEFAULT_STORAGE=20Gi

MATRIX_HOMESERVER=https://matrix.org
MATRIX_USER_ID=@dcf-light-bot:matrix.org
MATRIX_ACCESS_TOKEN=
MATRIX_WEBHOOK_SECRET=dev-matrix-secret

CONTROL_PLANE_ADMIN_TOKEN=dev-admin-token
CONTROL_PLANE_JWT_SECRET=dev-jwt-secret
CONTROL_PLANE_JWT_EXPIRES_SEC=28800
CONTROL_PLANE_USERS_JSON=[{"username":"admin","role":"platform_admin","password":"plain:admin123"},{"username":"reviewer","role":"reviewer","password":"plain:review123"},{"username":"ops","role":"ops_admin","password":"plain:ops123"},{"username":"auditor","role":"auditor","password":"plain:audit123"}]

BOOTSTRAP_INTERVAL_MS=5000
BOOTSTRAP_PROVISIONING_TIMEOUT_MS=120000
AUDIT_RETENTION_ENABLED=true
AUDIT_RETENTION_INTERVAL_MS=600000
AUDIT_RETENTION_TTL_DAYS=30
AUDIT_RETENTION_MAX_ROWS=5000
AUDIT_ARCHIVE_ENABLED=true
AUDIT_ARCHIVE_MAX_ROWS=20000
ASSET_REVIEW_SLA_ENABLED=true
ASSET_REVIEW_SLA_INTERVAL_MS=300000
ASSET_REVIEW_SLA_HOURS=24
ASSET_REVIEW_ESCALATION_MAX_LEVEL=3
ASSET_REVIEW_ESCALATION_COOLDOWN_HOURS=4
ASSET_REVIEW_ESCALATION_ROLE=platform_admin
METRICS_ENABLED=true
METRICS_REFRESH_INTERVAL_MS=60000
HEALTH_UNHEALTHY_OVERDUE_THRESHOLD=20
HEALTH_UNHEALTHY_DEGRADED_EVENT_THRESHOLD=20
HEALTH_UNHEALTHY_FAILED_INSTANCES_THRESHOLD=5
HEALTH_DEGRADED_OVERDUE_THRESHOLD=1
HEALTH_DEGRADED_ESCALATED_THRESHOLD=1
HEALTH_DEGRADED_EVENT_THRESHOLD=1
HEALTH_DEGRADED_FAILED_INSTANCES_THRESHOLD=1
RUNTIME_PROXY_INVOKE_PATH=/api/runtime/invoke
RUNTIME_PROXY_TIMEOUT_MS=10000
RUNTIME_PROXY_MAX_RETRIES=2
RUNTIME_PROXY_RETRY_BACKOFF_MS=200
RUNTIME_PROXY_FAILURE_THRESHOLD=3
RUNTIME_PROXY_BREAKER_COOLOFF_MS=30000
RUNTIME_PROXY_SHARED_TOKEN=

OPENAI_API_KEY=replace_me
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
MINIMAX_API_KEY=
